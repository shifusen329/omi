GOOGLE_APPLICATION_CREDENTIALS=google-credentials.json

# Primary document store: set DB_BACKEND=mongo to use local MongoDB via the
# firestore_compat shim. Leave empty to use Firestore SaaS.
DB_BACKEND=mongo
MONGO_URI=mongodb://localhost:27017/?replicaSet=rs0
MONGO_DB=omi

# --- Vector DB ---
# Set VECTOR_DB=pgvector for self-hosted Postgres + pgvector (embedding dim 1536).
# Leave unset to use the legacy Pinecone backend (requires the PINECONE_* vars below).
VECTOR_DB=pgvector
POSTGRES_URL=postgresql://omi_user:omi_password@localhost:5432/omi_db
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# --- Redis ---
REDIS_DB_HOST=
REDIS_DB_PORT=6379
REDIS_DB_PASSWORD=

# --- STT ---
# STT_SERVICE: deepgram (SaaS) or local_whisper (self-hosted WS speaking Deepgram protocol).
STT_SERVICE=local_whisper
STT_WS_URL=ws://192.168.0.107:8000/v1/listen
STT_WS_MODEL=turbo
STT_BATCH_URL=http://192.168.0.107:8000/v1/audio/transcriptions
STT_BATCH_MODEL=large-v3
DEEPGRAM_API_KEY=

